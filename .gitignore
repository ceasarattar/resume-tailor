data/jobs.sqlite
data/queue.json

# Real application facts (demographics, work auth, etc.) — personal, per-machine
profile/application.json

# Tectonic cache + locally-downloaded Tectonic binary
.tectonic/
**/tectonic-cache/
.tools/

# OS noise
.DS_Store
Thumbs.db

# Local Claude Code settings
.claude/settings.local.json

# NOTE: outputs/ is intentionally TRACKED (PDFs are tiny and double as a record).

