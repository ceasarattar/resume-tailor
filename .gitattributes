# Normalize line endings across macOS + Windows
* text=auto

*.py  text eol=lf
*.tex text eol=lf
*.md  text eol=lf
*.sh  text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.json text eol=lf
*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf

*.bat text eol=crlf
*.ps1 text eol=crlf

*.pdf binary
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
